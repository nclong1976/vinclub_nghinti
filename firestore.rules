// firestore.rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────────
    // Helper Functions
    // ───────────────────────────────────────────

    // Kiểm tra user đã đăng nhập
    function isAuthenticated() {
      return request.auth != null;
    }

    // Kiểm tra chính chủ
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Kiểm tra là admin (dựa vào tài liệu trong Firestore hoặc hardcode)
    function isAdmin() {
      return isAuthenticated() &&
             (request.auth.uid == 'anhleo4444' ||
              request.auth.uid == 'profile' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'finance_admin' ||
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'support_admin')));
    }

    // Kiểm tra là super_admin
    function isSuperAdmin() {
      return isAuthenticated() &&
             (request.auth.uid == 'anhleo4444' ||
              request.auth.uid == 'profile' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'));
    }

    // ───────────────────────────────────────────
    // Users Collection
    // ───────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if true;

      match /transactions/{transactionId} {
        allow read, write: if true;
      }
    }

    // ───────────────────────────────────────────
    // Projects Collection
    // ───────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if true;
      allow write: if true; // Cần thiết để thực hiện client-side seeding khi mount ứng dụng
    }

    // ───────────────────────────────────────────
    // Stocks Collection
    // ───────────────────────────────────────────
    match /stocks/{symbol} {
      allow read: if true;
      allow write: if true; // Cần thiết để thực hiện client-side seeding khi mount ứng dụng
    }

    // ───────────────────────────────────────────
    // Casino Games Collection
    // ───────────────────────────────────────────
    match /casinoGames/{gameId} {
      allow read: if true;
      allow write: if true; // Cần thiết để thực hiện client-side seeding khi mount ứng dụng
    }

    // ───────────────────────────────────────────
    // Articles Collection
    // ───────────────────────────────────────────
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true; // Cần thiết để thực hiện client-side seeding khi mount ứng dụng
    }

    // ───────────────────────────────────────────
    // Notifications Collection
    // ───────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if true; // Cần thiết để thực hiện client-side seeding khi mount ứng dụng
    }

    // ───────────────────────────────────────────
    // Chat Messages Collection
    // ───────────────────────────────────────────
    match /chat_messages/{messageId} {
      allow read, write: if true;
    }

    // ───────────────────────────────────────────
    // Audit Logs (chỉ admin ghi, admin đọc)
    // ───────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read, write: if true;
    }

    // ───────────────────────────────────────────
    // Config / System / Settings Collections
    // ───────────────────────────────────────────
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /system/{systemId} {
      allow read, write: if true;
    }

    match /settings/{settingsId} {
      allow read, write: if true;
    }

    // Chặn tất cả các path khác
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
